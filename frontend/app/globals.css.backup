@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Cinzel:wght@400;500;600;700;800;900&family=MedievalSharp&family=VT323&display=swap');
@import "tailwindcss";

:root {
  --background: #0d0d0f;
  --foreground: #f4f4f5;
  --font-sans: 'Inter', sans-serif;
  --font-display: 'MedievalSharp', cursive;
  --font-serif: 'Cinzel', serif;
  --font-pixel: 'VT323', monospace;
}

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --font-sans: var(--font-sans);
  --font-display: var(--font-display);
  --font-serif: var(--font-serif);
  --font-pixel: var(--font-pixel);
  
  /* Game-Specific MMORPG Colors */
  --color-game-gold: #e5c158;
  --color-game-gold-dark: #b89030;
  --color-game-iron: #3a3b40;
  --color-game-iron-dark: #1e1f22;
  --color-game-bronze: #8c5a3c;
  --color-game-wood: #2a1810;
  --color-game-wood-light: #4a2c1d;
  --color-game-stone: #24252a;
  --color-game-stone-dark: #141518;
  --color-game-parchment: #f4edd8;
  --color-game-parchment-dark: #dfd2b5;
  --color-game-crimson: #991b1b;
  --color-game-emerald: #065f46;
  
  --animate-glow-pulse: glow-pulse 2.5s infinite ease-in-out;
  --animate-float-embers: float-embers 20s infinite linear;
}

@keyframes glow-pulse {
  0%, 100% {
    filter: drop-shadow(0 0 4px rgba(229, 193, 88, 0.3));
    box-shadow: 0 0 10px rgba(229, 193, 88, 0.15);
  }
  50% {
    filter: drop-shadow(0 0 12px rgba(229, 193, 88, 0.6));
    box-shadow: 0 0 25px rgba(229, 193, 88, 0.35);
  }
}

@keyframes float-embers {
  0% {
    transform: translateY(100vh) translateX(0) scale(1);
    opacity: 0;
  }
  10% {
    opacity: 0.6;
  }
  90% {
    opacity: 0.6;
  }
  100% {
    transform: translateY(-10vh) translateX(50px) scale(0.5);
    opacity: 0;
  }
}

body {
  background-color: var(--background);
  color: var(--foreground);
  font-family: var(--font-sans);
  overflow-x: hidden;
  background-image: radial-gradient(circle at 50% 30%, rgba(26, 17, 10, 0.4) 0%, rgba(13, 13, 15, 0.98) 70%);
}

h1, h2, h3, h4, h5, h6 {
  font-family: var(--font-display);
}

/* --- Skeuomorphic Panel Styles --- */

/* Carved Stone Panel (Used for central panels, inventory, lists) */
.rpg-panel-stone {
  position: relative;
  background: linear-gradient(135deg, #1c1d22 0%, #111215 100%);
  border: 4px solid #32353f;
  box-shadow: 
    inset 0 0 15px rgba(0, 0, 0, 0.8),
    0 10px 25px rgba(0, 0, 0, 0.8);
  outline: 1px solid #141518;
  outline-offset: -5px;
}
/* Inner decorative gold highlight lines */
.rpg-panel-stone::before {
  content: '';
  position: absolute;
  inset: 5px;
  border: 1px solid rgba(229, 193, 88, 0.15);
  pointer-events: none;
}

/* Ornate Wood Panel (Used for outer screens, HUD overlays, high-priority frames) */
.rpg-panel-wood {
  position: relative;
  background: linear-gradient(135deg, #2e1a12 0%, #160d09 100%);
  border: 6px solid #8c5a3c;
  box-shadow: 
    inset 0 0 20px rgba(0, 0, 0, 0.9),
    0 15px 35px rgba(0, 0, 0, 0.9);
  outline: 2px solid #160d09;
}
/* Inner ornate frame details for wood panels */
.rpg-panel-wood::before {
  content: '';
  position: absolute;
  inset: 3px;
  border: 2px solid #e5c158;
  opacity: 0.85;
  pointer-events: none;
}
.rpg-panel-wood::after {
  content: '';
  position: absolute;
  inset: 7px;
  border: 1px solid #160d09;
  pointer-events: none;
}

/* Aged Parchment Panel (Used for mail, logs, updates) */
.rpg-panel-parchment {
  position: relative;
  background: linear-gradient(180deg, #f4edd8 0%, #e8dbae 100%);
  border: 3px solid #5c4033;
  color: #382212;
  font-family: var(--font-serif);
  box-shadow: 
    inset 0 0 12px rgba(92, 64, 51, 0.35),
    0 8px 20px rgba(0, 0, 0, 0.6);
}

/* --- Interactive MMORPG Elements --- */

/* Gold-Trimmed Iron Button with 3D press feel */
.rpg-button {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-weight: bold;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: #f4f4f5;
  background: linear-gradient(180deg, #4b4c54 0%, #292a30 100%);
  border: 2px solid #e5c158;
  box-shadow: 
    0 4px 0 #8c5a3c,
    0 6px 12px rgba(0, 0, 0, 0.7);
  transition: all 0.1s ease;
  cursor: pointer;
  outline: none;
}
.rpg-button:hover {
  background: linear-gradient(180deg, #595a63 0%, #34363e 100%);
  border-color: #f4d068;
  filter: brightness(1.1);
  box-shadow: 
    0 4px 0 #a36b47,
    0 8px 16px rgba(229, 193, 88, 0.25);
}
.rpg-button:active {
  transform: translateY(4px);
  box-shadow: 
    0 0px 0 transparent,
    0 2px 4px rgba(0, 0, 0, 0.8);
}
.rpg-button:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none !important;
  box-shadow: 0 4px 0 #2a2a2e !important;
  background: #2a2a2e !important;
  border-color: #555 !important;
}

/* Crimson Combat/Cancel Button variant */
.rpg-button-crimson {
  background: linear-gradient(180deg, #b91c1c 0%, #7f1d1d 100%);
  border-color: #ef4444;
  box-shadow: 
    0 4px 0 #5f1212,
    0 6px 12px rgba(0, 0, 0, 0.7);
}
.rpg-button-crimson:hover {
  background: linear-gradient(180deg, #dc2626 0%, #991b1b 100%);
  border-color: #f87171;
  box-shadow: 
    0 4px 0 #7f1d1d,
    0 8px 16px rgba(239, 68, 68, 0.25);
}

/* Emerald Green/Success Button variant */
.rpg-button-emerald {
  background: linear-gradient(180deg, #059669 0%, #064e3b 100%);
  border-color: #10b981;
  box-shadow: 
    0 4px 0 #064e3b,
    0 6px 12px rgba(0, 0, 0, 0.7);
}
.rpg-button-emerald:hover {
  background: linear-gradient(180deg, #10b981 0%, #047857 100%);
  border-color: #34d399;
  box-shadow: 
    0 4px 0 #047857,
    0 8px 16px rgba(16, 185, 129, 0.25);
}

/* Inset Carved Input Box */
.rpg-input {
  background: #0f1013;
  border: 2px solid #2e3037;
  color: #f4f4f5;
  font-family: var(--font-sans);
  box-shadow: inset 0 2px 5px rgba(0, 0, 0, 0.85);
  transition: all 0.2s ease;
}
.rpg-input:focus {
  outline: none;
  border-color: #e5c158;
  box-shadow: 
    inset 0 2px 5px rgba(0, 0, 0, 0.85),
    0 0 8px rgba(229, 193, 88, 0.35);
}
.rpg-input::placeholder {
  color: #52525b;
}

/* --- Atmospheric Decorative Elements --- */

/* Rising Embers Background overlay */
.rpg-embers-container {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
  z-index: 1;
  mix-blend-mode: screen;
}
.rpg-ember {
  position: absolute;
  bottom: -20px;
  width: 4px;
  height: 4px;
  background: radial-gradient(circle, #ffae19 0%, rgba(229, 88, 10, 0) 70%);
  border-radius: 50%;
  filter: blur(1px);
  animation: float-embers 15s infinite linear;
}

/* Ornate Corner Rivets / Studs */
.rpg-rivet {
  position: absolute;
  width: 8px;
  height: 8px;
  background: radial-gradient(circle, #e5c158 20%, #4a2c1d 80%);
  border: 1px solid #160d09;
  border-radius: 50%;
  box-shadow: 1px 1px 2px rgba(0, 0, 0, 0.6);
  z-index: 5;
}

/* Divider Line */
.rpg-divider {
  height: 4px;
  background: linear-gradient(90deg, transparent 0%, #e5c158 50%, transparent 100%);
  margin: 1.5rem 0;
  opacity: 0.6;
}

/* Monospace statistics indicators */
.rpg-stats-value {
  font-family: var(--font-pixel);
  font-size: 1.25rem;
  letter-spacing: 0.05em;
}

/* Custom Scrollbars */
::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}
::-webkit-scrollbar-track {
  background: #0d0d0f;
  border-left: 2px solid #24252a;
}
::-webkit-scrollbar-thumb {
  background: linear-gradient(180deg, #4a2c1d 0%, #2a1810 100%);
  border: 2px solid #0d0d0f;
  border-radius: 4px;
}
::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(180deg, #5c3928 0%, #3a2217 100%);
}

/* =============================================================================
   AAA STRATEGY GAME UI OVERHAUL CLASSES
   ============================================================================= */

/* Game Shell Layout */
.game-shell-container {
  display: grid;
  grid-template-rows: 4rem 1fr;
  grid-template-columns: auto 1fr auto;
  grid-template-areas:
    "topbar topbar topbar"
    "sidebar main center-right";
  height: 100vh;
  overflow: hidden;
}

/* Map Canvas Container */
.map-canvas-container {
  position: absolute;
  inset: 0;
  z-index: 0;
  background-color: #0b0c10;
  overflow: hidden;
}

.map-water-shimmer {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle, rgba(229,193,88,0.06) 0%, transparent 80%);
  mix-blend-mode: color-dodge;
  animation: water-shimmer 8s infinite ease-in-out;
  pointer-events: none;
}

@keyframes water-shimmer {
  0% { opacity: 0.25; }
  50% { opacity: 0.4; }
  100% { opacity: 0.25; }
}

.map-cloud-overlay {
  position: absolute;
  pointer-events: none;
  mix-blend-mode: color-dodge;
  opacity: 0.08;
  width: 500px;
  height: 300px;
  background: radial-gradient(ellipse, rgba(255,255,255,0.2) 0%, transparent 70%);
  filter: blur(40px);
}

.map-cloud-1 {
  animation: drift-clouds 90s infinite linear;
  top: 10%;
}

.map-cloud-2 {
  animation: drift-clouds 140s infinite linear;
  animation-delay: -50s;
  top: 40%;
}

@keyframes drift-clouds {
  0% { transform: translate(-100%, -20%) scale(1); }
  100% { transform: translate(100vw, 20%) scale(1.2); }
}

/* Ornate RPG HUD & Panel Styles */
.rpg-hud-panel {
  background: linear-gradient(135deg, #18191d 0%, #0d0e11 100%);
  border: 2px solid #3c3d42;
  box-shadow: 
    inset 0 0 10px rgba(0, 0, 0, 0.8),
    0 4px 12px rgba(0, 0, 0, 0.7);
  position: relative;
}

.rpg-hud-panel::before {
  content: '';
  position: absolute;
  inset: 1px;
  border: 1px solid #e5c158;
  opacity: 0.15;
  pointer-events: none;
}

/* Ornate Player Avatar Frame */
.rpg-avatar-circle {
  border: 2.5px solid #e5c158;
  box-shadow: 
    0 0 10px rgba(229, 193, 88, 0.35),
    0 4px 10px rgba(0, 0, 0, 0.8);
}

/* Customized Level and Energy bars */
.rpg-progress-blue {
  background: linear-gradient(90deg, #1e40af 0%, #3b82f6 100%);
  box-shadow: 0 0 6px rgba(59, 130, 246, 0.5);
}

.rpg-progress-red {
  background: linear-gradient(90deg, #991b1b 0%, #ef4444 100%);
  box-shadow: 0 0 6px rgba(239, 68, 68, 0.5);
}

/* Window overlays styles */
.game-window-overlay {
  position: absolute;
  inset: 0;
  z-index: 20;
  pointer-events: none;
}

.game-window {
  position: absolute;
  pointer-events: auto;
  background: linear-gradient(135deg, #1a1b20 0%, #0f1013 100%);
  border: 3px solid #3a3b40;
  box-shadow: 
    inset 0 0 15px rgba(0, 0, 0, 0.9),
    0 15px 35px rgba(0, 0, 0, 0.95);
  display: flex;
  flex-direction: column;
  transition: opacity 0.15s ease-out, transform 0.15s ease-out;
}

.game-window-active {
  z-index: 35 !important;
  border-color: #e5c158;
  box-shadow: 
    inset 0 0 15px rgba(0, 0, 0, 0.9),
    0 15px 45px rgba(0, 0, 0, 0.95),
    0 0 12px rgba(229, 193, 88, 0.15);
}

.game-window-header {
  cursor: move;
  cursor: grab;
  user-select: none;
  background: linear-gradient(180deg, #2e2f34 0%, #151619 100%);
  border-bottom: 2px solid #3c3d42;
}

.game-window-header:active {
  cursor: grabbing;
}

.game-window-active .game-window-header {
  border-bottom-color: #e5c158;
}

